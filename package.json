{
  "name": "page-translator",
  "version": "0.1.0",
  "private": true,
  "description": "Google翻訳でページ全体を翻訳するChromium拡張機能",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "gen-icons": "tsx scripts/gen-icons.ts",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsx tests/e2e/translate.test.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/chrome": "latest",
    "esbuild": "latest",
    "puppeteer": "latest",
    "sharp": "latest",
    "tsx": "latest",
    "typescript": "^5.5.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=20"
  }
}
